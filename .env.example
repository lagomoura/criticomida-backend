# Backend env template. Copy to `.env` for local dev:
#   cp .env.example .env
#
# Two run modes are supported locally:
#   1. Full-docker (default, recommended): api + db inside docker compose.
#      Use the DATABASE_URL below as-is (`db:5432`).
#   2. Hybrid: db in docker, uvicorn on host. Swap the DATABASE_URL host
#      to `localhost:5433` (compose maps host :5433 -> container :5432).
#
# Production (Railway) does NOT read this file. All env vars are set via
# Railway dashboard. DATABASE_URL is auto-injected by the Postgres service.

# Database
DATABASE_URL=postgresql+asyncpg://criticomida:criticomida_secret@db:5432/criticomida
POSTGRES_USER=criticomida
POSTGRES_PASSWORD=criticomida_secret
POSTGRES_DB=criticomida

# JWT (use >=32 random chars; never the placeholder in production)
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=palato-api
JWT_AUDIENCE=palato-clients
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
# Set true when serving the API over HTTPS (required for Secure cookies in prod)
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://criticomida-production.vercel.app

# Image generation (fal.ai)
FAL_KEY=

# Chat (google-genai). Both agents (Sommelier B2C y Business B2B)
# corren sobre Gemini via google-genai directo. Bare model name (sin
# prefijo gemini/ ni vertex_ai/). CHAT_API_KEY es la API key de
# Google AI Studio; google-genai la usa para enrutarse a AI Studio.
CHAT_MODEL=gemini-3.1-flash-lite-preview
CHAT_API_KEY=
# Optional per-agent overrides. Both fall back to CHAT_MODEL if unset.
CHAT_MODEL_B2C=
CHAT_MODEL_B2B=

# Gemini (embeddings + vision). Without it, the bot falls back to
# structured-only ranking and Ghostwriter can't tag photos.
GEMINI_API_KEY=
EMBEDDINGS_MODEL=gemini-embedding-2

# Google Places
GOOGLE_PLACES_API_KEY=

# Email transaccional (Resend). Cuando RESEND_API_KEY está vacío el servicio
# cae a dry-run (loguea el payload, no envía). En prod las 3 son obligatorias
# para que llegue el email de verificación al registrarse.
#   - EMAIL_FROM: el dominio debe estar verificado en Resend. Para pruebas
#     se puede usar `onboarding@resend.dev` (preverificado por Resend).
#   - PUBLIC_APP_URL: base usada para construir links de los emails
#     (verify-email, password reset, owner panel). Sin esto los links
#     apuntan a http://localhost:3000 y rompen el flujo en prod.
RESEND_API_KEY=
EMAIL_FROM=Palato <noreply@palato.me>
PUBLIC_APP_URL=http://localhost:3000

# Sentry. Vacío deshabilita el SDK por completo (default en dev).
# En prod (Railway): setear SENTRY_DSN; el release lo lee solo de
# RAILWAY_GIT_COMMIT_SHA si SENTRY_RELEASE está vacío.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Kill switches (cambiar acá + redeploy) ────────────────────────────
# ASYNC_JOB_WORKER_ENABLED=false → desactiva el worker in-process que
#   drena la cola async_job (re-embed/sentiment). La API sigue sirviendo
#   normal pero los jobs quedan acumulándose. Usalo si el worker se cuelga.
ASYNC_JOB_WORKER_ENABLED=true
# AGENT_LOOP_CACHE_DISABLED=1 → desactiva el context caching de Gemini
#   en el chatbot. Cae a system_instruction + tools inline cada turn
#   (más caro en tokens). Usalo si el caching produce respuestas raras
#   o si Gemini cambia la API del cache.
AGENT_LOOP_CACHE_DISABLED=
